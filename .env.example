# EKA Next.js Prototype - Environment Variables
# Copy this file to .env.local and update with your values

# ============================================================
# DATABASE CONFIGURATION
# ============================================================

# METHOD 1: Cloud PostgreSQL (Recommended)
# For Neon, AWS RDS, Render, Railway, Supabase, etc.
# Uncomment and use ONE of these:

# Neon (Active):
DATABASE_URL=postgresql://neondb_owner:password@ep-cool-lab-12345.us-east-1.neon.tech/neondb?sslmode=require

# AWS RDS Example:
# DATABASE_URL=postgresql://admin:password@my-instance.xxxxx.us-east-1.rds.amazonaws.com:5432/eka_db?sslmode=require

# Render Example:
# DATABASE_URL=postgresql://user:password@dpg-xxxxx.render.com/eka_db?sslmode=require

# Railway Example:
# DATABASE_URL=postgresql://user:password@railway.app:5432/eka_db?sslmode=require

# Supabase Example:
# DATABASE_URL=postgresql://postgres:password@xxxxx.supabase.co:5432/postgres?sslmode=require

# METHOD 2: Local PostgreSQL
# Use individual parameters instead of DATABASE_URL
# (Comment out METHOD 1 if using this)

# DATABASE_URL=postgresql://putu_a@localhost:5432/eka_db

# Or use separate parameters (if DATABASE_URL not set):
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=eka_db
# DB_USER=postgres
# DB_PASSWORD=
# DB_SSL=false

# ============================================================
# APPLICATION SETTINGS
# ============================================================

# Node environment
NODE_ENV=development
# NODE_ENV=production

# API Base URL (for client-side requests)
NEXT_PUBLIC_API_URL=http://localhost:3000

# ============================================================
# OPENAI CONFIGURATION
# ============================================================

# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Embedding model (advanced)
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536

# PDF Processing (advanced)
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# ============================================================
# GMAIL INTEGRATION (Optional)
# ============================================================

# Get from: https://console.cloud.google.com
GOOGLE_CLIENT_ID=xxxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxx
GOOGLE_REDIRECT_URI=http://localhost:3000/api/gmail/callback

# ============================================================
# NOTES
# ============================================================

# - For cloud databases: use DATABASE_URL (includes sslmode=require)
# - For local: use DB_* parameters or DATABASE_URL without SSL
# - Never commit real API keys to git
# - Use .env.local for local development (git-ignored)
# - Use Vercel/hosting environment variables for production
